# Virtual environments
venv/
.venv/

# Environment variables
.env
.env.*

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# pybaseball local cache
.pybaseball/

# IDE and tooling
.claude/
.vscode/
.idea/

# OS
.DS_Store

# Lahman data: only the CSVs the loader actually reads + the trimmed Chadwick
# bridge are committed. Everything else (raw Chadwick register, aux Lahman
# tables like Fielding/Salaries/HallOfFame, readme files) stays local.
backend/data/lahman/*
!backend/data/lahman/Batting.csv
!backend/data/lahman/Pitching.csv
!backend/data/lahman/People.csv
!backend/data/lahman/chadwick_mlb.csv
